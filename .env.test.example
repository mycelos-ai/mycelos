# Mycelos — Integration Test Environment
#
# Copy this to .env.test and fill in the keys/hosts you want to test with:
#     cp .env.test.example .env.test
#
# .env.test is gitignored — never commit real keys.
# Integration tests are skipped unless you run: pytest -m integration
# Each test only runs when its required env var is set, so a partial
# .env.test (e.g. only OLLAMA_HOST) is fine.


# ─── Cloud LLM providers ──────────────────────────────────────────────
# Real API calls → real cost. Cassette recordings under tests/cassettes/
# allow most tests to replay without hitting the API.

# Anthropic Claude — used by the default integration_app fixture
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI — opt-in for OpenAI-specific tests
# OPENAI_API_KEY=sk-...


# ─── Local LLMs ───────────────────────────────────────────────────────
# Ollama and LM Studio expose local models via HTTP. No API keys needed.
# The integration_app_local fixture and local-LLM smoke tests use these.

# Ollama HTTP endpoint. Common values:
#   http://localhost:11434
#   http://minimac.local:11434  (LAN host)
#   http://host.docker.internal:11434  (from inside Docker)
# OLLAMA_HOST=http://minimac.local:11434

# LM Studio HTTP endpoint (OpenAI-compatible). Include the /v1 suffix.
# LM_STUDIO_HOST=http://minimac.local:1234/v1


# ─── Search & web connectors ──────────────────────────────────────────
# BRAVE_API_KEY=BSA...


# ─── Telegram ─────────────────────────────────────────────────────────
# Get a bot token from @BotFather. Used by test_telegram_live.py and the
# connector setup flow tests.
# TELEGRAM_BOT_TOKEN=1234567890:AA...


# ─── Gmail ────────────────────────────────────────────────────────────
# Use an App Password, not your regular Google password.
# https://support.google.com/accounts/answer/185833
# GMAIL_USER=you@gmail.com
# GMAIL_PASSWORD="xxxx xxxx xxxx xxxx"

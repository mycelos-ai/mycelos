# Mycelos — Environment Variables
#
# Copy this file:  cp .env.example .env
# Then edit .env with your values.
#
# After first start, REMOVE the LLM_API_KEY line (it's encrypted in the DB).

# LLM API Key (required for first start, auto-detects provider)
# Anthropic:  sk-ant-api03-...
# OpenAI:     sk-...
# Ollama:     http://localhost:11434 (or http://host.docker.internal:11434 from Docker)
LLM_API_KEY=

# Master encryption key (auto-generated if empty — leave blank for most setups)
# MYCELOS_MASTER_KEY=

# Basic Auth password (RECOMMENDED when exposing Mycelos on your network)
# Set a strong password to protect the web UI. If empty, no auth is required.
# MYCELOS_PASSWORD=your-strong-password-here
